# Local dev secrets for scripts/dev-local.sh
#
# Copy to `.env.local` (gitignored via *.local) and fill in your values:
#   cp .env.local.example .env.local
#
# Your WeChat Mini Program AppID (required for login + devtools).
WX_APPID=
# Your WeChat Mini Program AppSecret (required so the backend can call
# code2session and issue a JWT; without it, login-gated pages won't work).
WX_SECRET=

# Optional: override the WeChat DevTools CLI path if not at the default
# location (/Applications/wechatwebdevtools.app/Contents/MacOS/cli).
# WX_DEVTOOLS_CLI=
