# Client environment variables (Vite).
#
# Copy this file to the env file matching the build mode:
#   .env.development  → loaded by `npm run dev:mp-weixin`   (uni dev, mode=development)
#   .env.production   → loaded by `npm run build:mp-weixin` (uni build, mode=production)
# All client/.env* files are gitignored except this example. In CI, the
# production values are injected via GitHub Secrets and override any file value.

# Backend API base URL. Falls back to http://localhost:3000 if unset.
VITE_API_BASE_URL=https://api.example.com
