# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRES_IN=2h
JWT_REFRESH_SECRET=change-me-to-another-random-secret
JWT_REFRESH_EXPIRES_IN=30d

# WeChat Mini Program
WX_APPID=your-appid
WX_SECRET=your-app-secret

# Admin console
# Username is required. Avoid using the default 'admin'.
ADMIN_USERNAME=admin
# Password: choose one of the following options.
#   Recommended: ADMIN_PASSWORD_HASH (bcrypt hash)
#     Generate with: node -e "require('bcrypt').hash('your-password', 10).then(console.log)"
#   Or: ADMIN_PASSWORD (plain text, development or quick trials only)
# The default placeholder 'change-me-to-a-strong-password' is rejected by the server to prevent accidental production use.
ADMIN_PASSWORD=change-me-to-a-strong-password
# ADMIN_PASSWORD_HASH=
# GitHub Issues feedback integration
# Fine-grained PAT with Issues read/write permissions.
# GH_ISSUES_TOKEN=<github-token>
# Target repo for user feedback issues, e.g. owner/repo
# GH_ISSUES_REPO=your-org/your-repo

# Storage (use OSS in production)
# STORAGE_DRIVER=oss
# OSS_REGION=oss-cn-shanghai
# OSS_BUCKET=your-bucket-name
# OSS_ACCESS_KEY_ID=your-access-key-id
# OSS_ACCESS_KEY_SECRET=your-access-key-secret
# OSS_CDN_DOMAIN=cdn.example.com
# OSS_PREFIX=uploads/
